# TapON SSP credentials (server-side only — không commit .env.local)
TAPON_BASE_URL=https://ssp.tapon.vn/api/v1
TAPON_CLIENT_ID=oohx_marketplace
TAPON_CLIENT_SECRET=

# Webhook secret — tự đặt, min 16 ký tự
TAPON_WEBHOOK_SECRET=

# Domain của OOHX (dùng khi chạy register-webhook script)
OOHX_DOMAIN=https://oohx.net
